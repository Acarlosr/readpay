# ============================================================
# ReadPay — Environment Variables
# Copy to .env and fill in your values.
# NEVER commit .env or private keys.
# ============================================================

# ----- Arc Testnet (valores oficiais, não mudam) -----
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
ARC_EXPLORER=https://testnet.arcscan.app

# ----- Contratos Arc Testnet (endereços oficiais) -----
# USDC ERC-20 interface (6 decimals)
USDC_CONTRACT=0x3600000000000000000000000000000000000000
# Circle Gateway Wallet contract
GATEWAY_WALLET_ADDRESS=0x0077777d7EBA4688BDeF3E311b846F25870A19B9

# ----- Chave do leitor (apenas para dev local / demo) -----
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Obtenha USDC testnet em: https://faucet.circle.com (selecione Arc Testnet)
READER_PRIVATE_KEY=0x...sua_chave_privada_de_testnet...

# ----- Demo publisher server -----
# Endereço que receberá os pagamentos do demo (pode ser outra conta sua)
PUBLISHER_ADDRESS=0x...endereco_do_publisher...
PUBLISHER_PRIVATE_KEY=0x...chave_do_publisher...
DEMO_SERVER_PORT=3001

# ----- Limites padrão (editáveis também no popup da extensão) -----
DEFAULT_DAILY_LIMIT_USDC=2.00
DEFAULT_PER_ARTICLE_MAX_USDC=0.10
AUTO_PAY=true
